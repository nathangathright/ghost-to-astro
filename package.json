{
  "name": "ghost-to-astro",
  "version": "0.1.0",
  "description": "Migrate a Ghost CMS site to Astro with MDX content collections",
  "type": "module",
  "bin": {
    "ghost-to-astro": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
