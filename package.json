  },
  "dependencies": {
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/turndown": "^5.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "sharp": "^0.33.0"
  },
  "license": "MIT"
}
